{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "crons": [
        {
            "path": "/api/cron-sync",
            "schedule": "0 10 * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/fintoc/create-link-intent",
            "destination": "/api/fintoc"
        },
        {
            "source": "/api/fintoc/webhook",
            "destination": "/api/fintoc"
        },
        {
            "source": "/api/fintoc/sync",
            "destination": "/api/fintoc"
        },
        {
            "source": "/api/debug",
            "destination": "/api/debug"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "https://finance.nexusnetwork.cl"
                },
                {
                    "key": "Access-Control-Allow-Methods",
                    "value": "GET,POST,OPTIONS"
                },
                {
                    "key": "Access-Control-Allow-Headers",
                    "value": "Content-Type"
                }
            ]
        }
    ]
}